{
  "name": "tata-project",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node --max-old-space-size=4096 node_modules/electron-builder/out/cli/cli.js"
  },
  "build": {
    "appId": "com.tata.hrms",
    "productName": "TataMemorialHospital",
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "server.js",
      "my-app/**/*",
      "data/**/*",
      "pdf_uploads/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data"
      }
    ]
  }
}